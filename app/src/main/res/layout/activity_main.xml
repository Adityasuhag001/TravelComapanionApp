<?xml version="1.0" encoding="utf-8"?>
<!-- Main layout - using LinearLayout to stack everything vertically -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <!-- App title -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Travel Companion"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="20dp"/>

    <!-- Dropdown to pick category (Currency, Fuel, Temperature) -->
    <Spinner
        android:id="@+id/categorySpinner"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"/>

    <!-- Dropdown to pick the source unit -->
    <Spinner
        android:id="@+id/fromSpinner"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"/>

    <!-- Dropdown to pick the destination unit -->
    <Spinner
        android:id="@+id/toSpinner"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginBottom="12dp"/>

    <!-- Text field where user types the number they want to convert -->
    <EditText
        android:id="@+id/inputField"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:hint="Enter value"
        android:inputType="numberDecimal|numberSigned"
        android:layout_marginBottom="12dp"/>

    <!-- Button to trigger the conversion -->
    <Button
        android:id="@+id/convertButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Convert"
        android:layout_marginBottom="20dp"/>

    <!-- Shows the converted result -->
    <TextView
        android:id="@+id/resultText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Result will show here"
        android:textSize="20sp"
        android:textAlignment="center"/>

</LinearLayout>